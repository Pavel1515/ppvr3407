# --- Admin area hardening ---

# Never let admin pages be indexed or framed.
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
    Header always set X-Robots-Tag "noindex, nofollow"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Block direct web access to the credentials file and any dotfiles/backups.
<FilesMatch "^(config\.php|.*\.(bak|old|inc|json|log))$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# --- OPTIONAL: restrict the whole admin panel to your own IP(s). ---
# Uncomment and replace with your address (find it at https://whatismyipaddress.com).
# <IfModule mod_authz_core.c>
#     <RequireAll>
#         Require ip 203.0.113.45
#     </RequireAll>
# </IfModule>
